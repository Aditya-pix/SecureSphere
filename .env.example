# Django
DJANGO_SETTINGS_MODULE=securesphere.settings
DJANGO_SECRET_KEY=replace-with-a-secure-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
APP_ENV=development
TIME_ZONE=UTC

# API
API_VERSION=v1

# CORS and CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Security
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_REFERRER_POLICY=same-origin

# PostgreSQL
POSTGRES_DB=securesphere
POSTGRES_USER=securesphere
POSTGRES_PASSWORD=replace-with-a-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=securesphere
MINIO_USE_SSL=false

# JWT
JWT_SECRET_KEY=replace-with-a-secure-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email
EMAIL_HOST=mail.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-email-username
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@example.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100
